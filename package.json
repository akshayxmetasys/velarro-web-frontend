{
  "name": "velarro-web-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:playwright": "playwright test",
    "agent-skills:sync": "python -B scripts/sync_agent_skills.py",
    "agent-skills:check": "python -B scripts/sync_agent_skills.py --check",
    "cursor:validate": "python -B scripts/validate_cursor_pack.py",
    "cursor:hooks:test": "python -B -m unittest discover .cursor/hooks/tests",
    "cursor:check": "npm run agent-skills:check && npm run cursor:validate && npm run cursor:hooks:test"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.1.2"
  }
}
