{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python ./.cursor/hooks/guard.py before-shell",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "python ./.cursor/hooks/guard.py after-edit",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "python ./.cursor/hooks/guard.py stop",
        "timeout": 10
      }
    ]
  }
}
